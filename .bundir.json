{
  "options": {
    "dryRun": false,
    "verbose": true,
    "defaultCategory": "others",
    "ignoreHidden": true
  },
  "categories": {
    "images": {
      "extensions": [".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp"],
      "targetDir": "media/images"
    },
    "videos": {
      "extensions": [".mp4", ".mkv", ".mov", ".avi"],
      "targetDir": "media/videos"
    },
    "audio": {
      "extensions": [".mp3", ".wav", ".ogg", ".flac"],
      "targetDir": "media/audio"
    },
    "documents": {
      "extensions": [".pdf", ".docx", ".txt", ".md", ".odt"],
      "targetDir": "documents"
    },
    "spreadsheets": {
      "extensions": [".xlsx", ".xls", ".csv", ".ods"],
      "targetDir": "data/spreadsheets"
    },
    "scripts": {
      "extensions": [".js", ".ts", ".py", ".sh", ".rb"],
      "targetDir": "code/scripts"
    },
    "archives": {
      "extensions": [".zip", ".rar", ".tar", ".gz", ".7z"],
      "targetDir": "archives"
    },
    "design": {
      "extensions": [".fig", ".psd", ".ai", ".xd"],
      "targetDir": "design"
    },
    "configs": {
      "extensions": [".json", ".yaml", ".yml", ".toml", ".ini"],
      "targetDir": "configs"
    }
  }
}
