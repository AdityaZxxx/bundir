{
  "name": "bundir",
  "version": "1.1.1",
  "description": "A CLI tool to organize files in a directory based on their type",
  "module": "src/index.ts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bundir": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "test": "bun test src/tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "file",
    "organize",
    "bundler",
    "directory",
    "cleanup",
    "files",
    "sort"
  ],
  "author": "AdityaZxxx",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
